# ==============================
# SprintRoom Backend Configuration
# ==============================
# Copy this file to .env and fill in your values

PORT=5000                          # Port the backend server runs on

MONGO_URI=mongodb://localhost:27017/sprintroom  # MongoDB connection string

JWT_SECRET=super_secret_jwt_key_sprintroom      # Secret key for signing auth tokens

NODE_ENV=development               # "development" uses in-memory fallback if MongoDB fails.
                                   # "production" will crash if MongoDB is unavailable.
